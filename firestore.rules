
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the requester has the 'admin' role.
     */
    function isAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    /** 
     * Validates if the user is a collaborator on a board-related resource.
     * Works for Boards, Columns, and Tasks due to denormalization.
     */
    function isBoardCollaborator(data) {
      return isSignedIn() && (
        request.auth.uid == data.ownerId || 
        (data.memberIds != null && data.memberIds.hasAny([request.auth.uid]))
      );
    }

    /**
     * Determines if a student can access a specific task.
     * Students ONLY see tasks they created. Teachers see everything in their own board.
     */
    function canStudentSeeTask(data) {
      return isSignedIn() && (
        request.auth.uid == data.ownerId || // The board owner (teacher)
        request.auth.uid == data.creatorId   // The individual student who created it
      );
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId);
    }

    match /boards/{boardId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // Filtered by board membership in app
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        isBoardCollaborator(resource.data) || 
        (request.resource.data.memberIds.hasAny([request.auth.uid]))
      );
      
      allow delete: if isSignedIn() && resource != null && resource.data.ownerId == request.auth.uid;
    }

    match /boards/{boardId}/columns/{columnId} {
      allow get, list: if isBoardCollaborator(resource.data);
      allow create: if isBoardCollaborator(request.resource.data);
      allow update: if isBoardCollaborator(resource.data);
      allow delete: if isBoardCollaborator(resource.data);
    }

    match /boards/{boardId}/columns/{columnId}/tasks/{taskId} {
      // READ: Students only see tasks they created. Teachers see everything on their board.
      allow read: if canStudentSeeTask(resource.data);
      
      // WRITE: User must be a member and either be the creator or the board owner.
      allow create, update: if isBoardCollaborator(request.resource.data) && (
        request.auth.uid == request.resource.data.creatorId || 
        request.auth.uid == request.resource.data.ownerId
      );
      
      allow delete: if canStudentSeeTask(resource.data);
    }
  }
}
