rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the requester has the 'admin' role globally.
     */
    function isAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    /** 
     * Validates if the user is a collaborator on a board-related resource.
     * Works for Boards, Columns, and Tasks due to denormalization.
     */
    function isBoardCollaborator(data) {
      return isSignedIn() && (
        request.auth.uid == data.ownerId || 
        (data.memberIds != null && data.memberIds.hasAny([request.auth.uid]))
      );
    }

    /**
     * Determines if a student can access a specific task.
     * Students ONLY see tasks they created. Teachers see everything in their own board.
     */
    function canStudentSeeTask(data) {
      return isSignedIn() && (
        request.auth.uid == data.ownerId || // The board owner (teacher)
        request.auth.uid == data.creatorId || // The individual student who created it
        request.auth.uid == data.assigneeId   // The student assigned to this task
      );
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId);
    }

    match /boards/{boardId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      
      // Board owner can do anything. Members can update (e.g., join via invite code).
      allow update: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid ||
        isBoardCollaborator(resource.data) || 
        (request.resource.data.memberIds.hasAny([request.auth.uid]))
      );
      
      allow delete: if isSignedIn() && resource != null && resource.data.ownerId == request.auth.uid;
    }

    match /boards/{boardId}/columns/{columnId} {
      allow get, list: if isBoardCollaborator(resource.data) || isBoardCollaborator(get(/databases/$(database)/documents/boards/$(boardId)).data);
      allow create: if isBoardCollaborator(request.resource.data);
      allow update: if isBoardCollaborator(resource.data);
      allow delete: if isBoardCollaborator(resource.data);
    }

    match /boards/{boardId}/columns/{columnId}/tasks/{taskId} {
      // Any board collaborator can read and list tasks. Privacy is enforced by app-level queries.
      allow read, list: if isBoardCollaborator(get(/databases/$(database)/documents/boards/$(boardId)).data);
      
      // Any board collaborator can create and update tasks.
      allow create, update: if isBoardCollaborator(request.resource.data);
      
      // Any board collaborator can delete tasks.
      allow delete: if isBoardCollaborator(resource.data);
    }
  }
}
