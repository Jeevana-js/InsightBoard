/**
 * SprintSync Board Security Rules
 * 
 * Core Philosophy:
 * This ruleset implements a robust, role-based access control (RBAC) and ownership model. 
 * It distinguishes between 'admin' (Teachers) and 'member' (Students). Teachers have 
 * elevated privileges, such as viewing all user profiles. Collaborative access to 
 * Kanban boards is managed through a membership model (owner + member list).
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the requester has the 'admin' role.
     * Performs a look-up to the user's profile document.
     */
    function isAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    /** 
     * Validates if the user is a collaborator on a board-related resource.
     * Works for Boards, Columns, and Tasks due to denormalization.
     */
    function isBoardCollaborator(data) {
      return isSignedIn() && (
        request.auth.uid == data.ownerId || 
        (data.memberIds != null && request.auth.uid in data.memberIds)
      );
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // Any signed-in user can 'get' a profile to see collaborator info
      allow get: if isSignedIn();
      
      // Only admins can list all users (e.g., for user management)
      allow list: if isAdmin();
      
      // Users can create their own profile
      allow create: if isOwner(userId);
      
      // Owners can update their own profile. 
      // Admins can update any profile (e.g., to promote a member to admin).
      allow update: if isOwner(userId) || isAdmin();
      
      // Owners can delete their own accounts
      allow delete: if isOwner(userId);
    }

    match /boards/{boardId} {
      // Allow getting a board by ID so students can verify a room code
      allow get: if isSignedIn();
      
      // Listing boards is restricted to collaborators
      allow list: if isBoardCollaborator(resource.data);
      
      // Teachers can create their own boards
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      
      // Update allowed if:
      // 1. User is already a collaborator
      // 2. User is joining and adding ONLY themselves to the member list
      allow update: if isSignedIn() && (
        isBoardCollaborator(resource.data) || 
        (request.resource.data.memberIds.hasAny([request.auth.uid]))
      );
      
      allow delete: if isSignedIn() && resource != null && resource.data.ownerId == request.auth.uid;
    }

    match /boards/{boardId}/columns/{columnId} {
      allow get, list: if isBoardCollaborator(resource.data);
      allow create: if isBoardCollaborator(request.resource.data);
      allow update: if isBoardCollaborator(resource.data) && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isBoardCollaborator(resource.data);
    }

    match /boards/{boardId}/columns/{columnId}/tasks/{taskId} {
      allow get, list: if isBoardCollaborator(resource.data);
      allow create: if isBoardCollaborator(request.resource.data);
      allow update: if isBoardCollaborator(resource.data) && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isBoardCollaborator(resource.data);
    }
  }
}