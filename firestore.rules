
/**
 * SprintSync Board Security Rules
 * 
 * Core Philosophy:
 * This ruleset implements a robust, role-based access control (RBAC) and ownership model. 
 * It distinguishes between 'admin' (Teachers) and 'member' (Students). Teachers have 
 * elevated privileges, such as viewing all user profiles. Collaborative access to 
 * Kanban boards is managed through a membership model (owner + member list).
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the requester has the 'admin' role.
     * Performs a look-up to the user's profile document.
     */
    function isAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    /** 
     * Validates if the user is a collaborator on a board-related resource.
     * Works for Boards, Columns, and Tasks due to denormalization.
     */
    function isBoardCollaborator(data) {
      return isSignedIn() && (
        request.auth.uid == data.ownerId || 
        (data.memberIds != null && data.memberIds.hasAny([request.auth.uid]))
      );
    }

    /**
     * Determines if a student can access a specific task.
     * Students ONLY see tasks they created. Teachers see everything in their board.
     */
    function canStudentSeeTask(data) {
      return isSignedIn() && (
        request.auth.uid == data.ownerId || // The board owner (teacher)
        request.auth.uid == data.creatorId   // The individual student who created it
      );
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId);
    }

    match /boards/{boardId} {
      allow get: if isSignedIn();
      allow list: if isBoardCollaborator(resource.data);
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      
      // Update allowed if already a collaborator or joining with their own UID
      allow update: if isSignedIn() && (
        isBoardCollaborator(resource.data) || 
        (request.resource.data.memberIds.hasAny([request.auth.uid]))
      );
      
      allow delete: if isSignedIn() && resource != null && resource.data.ownerId == request.auth.uid;
    }

    match /boards/{boardId}/columns/{columnId} {
      allow get, list: if isBoardCollaborator(resource.data);
      allow create: if isBoardCollaborator(request.resource.data);
      allow update: if isBoardCollaborator(resource.data) && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isBoardCollaborator(resource.data);
    }

    match /boards/{boardId}/columns/{columnId}/tasks/{taskId} {
      // Students only see tasks they created. Teachers see everything.
      allow read: if canStudentSeeTask(resource.data);
      
      // Create/Update: user must be a collaborator and set themselves as creator (or be owner)
      allow create, update: if isBoardCollaborator(request.resource.data) && (
        request.auth.uid == request.resource.data.creatorId || 
        request.auth.uid == request.resource.data.ownerId
      );
      
      allow delete: if canStudentSeeTask(resource.data);
    }
  }
}
